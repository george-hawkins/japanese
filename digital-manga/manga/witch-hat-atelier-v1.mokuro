}, {"box": [743, 831, 1506, 893], "vertical": false, "font_size": 62, "lines_coords": [[[743.0, 831.0], [1506.0, 831.0], [1506.0, 893.0], [743.0, 893.0]]], "lines": ["魔法陣を構成する３つの要素"]}, {"box": [925, 1222, 1317, 1391], "vertical": false, "font_size": 46, "lines_coords": [[[937.0, 1225.0], [1306.0, 1225.0], [1306.0, 1265.0], [937.0, 1265.0]], [[968.0, 1278.0], [1271.0, 1278.0], [1271.0, 1331.0], [968.0, 1331.0]], [[925.0, 1346.0], [1306.0, 1346.0], [1306.0, 1390.0], [925.0, 1390.0]]], "lines": ["紋の周りに描かれる。", "魔法が現れる形。", "大きさ、方向を決める"]}, {"box": [427, 1221, 778, 1393], "vertical": false, "font_size": 48, "lines_coords": [[[453.0, 1221.0], [750.0, 1221.0], [750.0, 1265.0], [453.0, 1265.0]], [[431.0, 1278.0], [768.0, 1278.0], [768.0, 1331.0], [431.0, 1331.0]], [[475.0, 1340.0], [721.0, 1346.0], [721.0, 1393.0], [475.0, 1387.0]]], "lines": ["中央に描かれる。", "紋の種類で魔法の", "効果が決まる"]}, {"box": [1673, 2038, 1791, 2406], "vertical": true, "font_size": 118, "lines_coords": [[[1673.0, 2038.0], [1791.0, 2038.0], [1791.0, 2406.0], [1673.0, 2406.0]]], "lines": ["ＴＶＣ－"]}, {"box": [925, 1643, 1328, 1684], "vertical": false, "font_size": 41, "lines_coords": [[[925.0, 1643.0], [1328.0, 1643.0], [1328.0, 1684.0], [925.0, 1684.0]]], "lines": ["浮遊の矢十柱の矢一収束の矢"]}, {"box": [842, 1880, 1370, 1939], "vertical": false, "font_size": 44, "lines_coords": [[[862.0, 1887.0], [1359.0, 1887.0], [1359.0, 1931.0], [862.0, 1931.0]]], "lines": ["具体的な魔法陣例"]}, {"box": [718, 1646, 806, 1681], "vertical": false, "font_size": 35, "lines_coords": [[[718.0, 1646.0], [806.0, 1646.0], [806.0, 1681.0], [718.0, 1681.0]]], "lines": ["水の紋"]}, {"box": [811, 1961, 1356, 2174], "vertical": false, "font_size": 43, "lines_coords": [[[818.0, 2018.0], [1168.0, 2018.0], [1168.0, 2071.0], [818.0, 2071.0]], [[821.0, 2087.0], [1165.0, 2087.0], [1165.0, 2128.0], [821.0, 2128.0]], [[821.0, 2134.0], [1318.0, 2131.0], [1318.0, 2165.0], [821.0, 2168.0]]], "lines": ["飛靴の裏の魔法陣", "左右の靴裏を合わせると", "安定した状態で空を飛ぶことができる"]}, {"box": [921, 2237, 1365, 2278], "vertical": false, "font_size": 41, "lines_coords": [[[921.0, 2237.0], [1365.0, 2237.0], [1365.0, 2278.0], [921.0, 2278.0]]], "lines": ["ダダ山脈で使った魔法陣"]}, {"box": [894, 2274, 1383, 2436], "vertical": false, "font_size": 38, "lines_coords": [[[903.0, 2300.0], [1237.0, 2303.0], [1237.0, 2346.0], [903.0, 2343.0]], [[912.0, 2350.0], [1368.0, 2350.0], [1368.0, 2390.0], [912.0, 2390.0]], [[909.0, 2396.0], [1325.0, 2396.0], [1325.0, 2428.0], [909.0, 2428.0]]], "lines": ["彼が中央からずれていて", "一本の矢が長く描かれているので", "瞬間的に強い｀魔法を発動した"]}, {"box": [550, 1637, 656, 1709], "vertical": false, "font_size": 37.5, "lines_coords": [[[550.0, 1637.0], [656.0, 1637.0], [656.0, 1668.0], [550.0, 1668.0]], [[556.0, 1665.0], [653.0, 1665.0], [653.0, 1709.0], [556.0, 1709.0]]], "lines": ["足場のある", "風の紋"]}, {"box": [406, 1646, 496, 1681], "vertical": false, "font_size": 35, "lines_coords": [[[406.0, 1646.0], [496.0, 1646.0], [496.0, 1681.0], [406.0, 1681.0]]], "lines": ["風の紋"]}, {"box": [361, 2037, 734, 2398], "vertical": false, "font_size": 361, "lines_coords": [[[361.0, 2037.0], [734.0, 2037.0], [734.0, 2398.0], [361.0, 2398.0]]], "lines": ["．．．いやいや、やっぱり"]}, {"box": [1254, 2556, 1661, 2837], "vertical": false, "font_size": 44, "lines_coords": [[[1275.0, 2556.0], [1540.0, 2556.0], [1540.0, 2596.0], [1275.0, 2596.0]], [[1265.0, 2593.0], [1537.0, 2587.0], [1537.0, 2640.0], [1265.0, 2646.0]], [[1259.0, 2665.0], [1656.0, 2665.0], [1656.0, 2706.0], [1259.0, 2706.0]], [[1259.0, 2709.0], [1515.0, 2709.0], [1515.0, 2753.0], [1259.0, 2753.0]], [[1259.0, 2753.0], [1478.0, 2753.0], [1478.0, 2796.0], [1259.0, 2796.0]], [[1259.0, 2793.0], [1503.0, 2793.0], [1503.0, 2837.0], [1259.0, 2837.0]]], "lines": ["ココがはじめて", "描いた魔法陣", "小さく明滅する光が発現した。", "禁止魔法の書から", "描き写したため、", "本来の効果は謎"]}, {"box": [319, 2529, 740, 2861], "vertical": false, "font_size": 38, "lines_coords": [[[346.0, 2534.0], [628.0, 2534.0], [628.0, 2565.0], [346.0, 2565.0]], [[340.0, 2575.0], [600.0, 2568.0], [600.0, 2612.0], [340.0, 2618.0]], [[340.0, 2643.0], [696.0, 2643.0], [696.0, 2684.0], [340.0, 2684.0]], [[331.0, 2690.0], [731.0, 2690.0], [731.0, 2721.0], [331.0, 2721.0]], [[328.0, 2731.0], [628.0, 2731.0], [628.0, 2771.0], [328.0, 2771.0]], [[328.0, 2775.0], [603.0, 2775.0], [603.0, 2815.0], [328.0, 2815.0]], [[325.0, 2818.0], [709.0, 2818.0], [709.0, 2859.0], [325.0, 2859.0]]], "lines": ["ココがアトリエで", "描いた魔法陣", "一本だけ矢が長かったため", "アガットを水浸し人にしてしまった", "ちなみに、キーフリーは", "水の魔法が得意で、", "「水の花」を作ったりもできる"]}], "img_path": "206.avif"}, {"version": "0.2.4", "img_width": 2250, "img_height": 3200, "blocks": [{"box": [459, 140, 1665, 278], "vertical": false, "font_size": 132, "lines_coords": [[[459.0, 146.0], [1665.0, 140.0], [1665.0, 271.0], [459.0, 278.0]]], "lines": ["雪とんがり帽子の世界"]}, {"box": [475, 371, 1781, 428], "vertical": false, "font_size": 54, "lines_coords": [[[475.0, 371.0], [1781.0, 375.0], [1781.0, 428.0], [475.0, 425.0]]], "lines": ["ココたちが住んでいる世界のごとな、少しだけご紹介します。"]}, {"box": [1587, 693, 2071, 787], "vertical": false, "font_size": 41.0, "lines_coords": [[[1593.0, 693.0], [2071.0, 693.0], [2071.0, 734.0], [1593.0, 734.0]], [[1587.0, 746.0], [2068.0, 746.0], [2068.0, 787.0], [1587.0, 787.0]]], "lines": ["山のふもとにある、田舎の小", "さな村。魔法を利用した道具"]}, {"box": [1640, 828, 1771, 1215], "vertical": true, "font_size": 57.5, "lines_coords": [[[1709.0, 834.0], [1771.0, 834.0], [1771.0, 1215.0], [1709.0, 1215.0]], [[1640.0, 828.0], [1693.0, 828.0], [1693.0, 1003.0], [1640.0, 1003.0]]], "lines": ["コ仕営り、少業って", "い家屋"]}, {"box": [1621, 1078, 1703, 1221], "vertical": true, "font_size": 58, "lines_coords": [[[1621.0, 1087.0], [1678.0, 1078.0], [1703.0, 1212.0], [1646.0, 1221.0]]], "lines": ["から伝"]}, {"box": [581, 2236, 1104, 2292], "vertical": false, "font_size": 56, "lines_coords": [[[581.0, 2236.0], [1104.0, 2236.0], [1104.0, 2292.0], [581.0, 2292.0]]], "lines": ["ＮＡＰＯＦＷｉｎｄｏｉｄＨＡＴ"]}, {"box": [1578, 1549, 2078, 1813], "vertical": false, "font_size": 40, "lines_coords": [[[1593.0, 1556.0], [2068.0, 1553.0], [2068.0, 1596.0], [1593.0, 1600.0]], [[1578.0, 1609.0], [2075.0, 1606.0], [2075.0, 1650.0], [1578.0, 1653.0]], [[1581.0, 1662.0], [2071.0, 1662.0], [2071.0, 1703.0], [1581.0, 1703.0]], [[1587.0, 1715.0], [2065.0, 1715.0], [2065.0, 1756.0], [1587.0, 1756.0]], [[1590.0, 1775.0], [1840.0, 1775.0], [1840.0, 1806.0], [1590.0, 1806.0]]], "lines": ["ココの村から少し離れたとこ", "ろに、ポツンと建っている。大", "講堂に居を構える魔法使いも", "多いが、キーフリーはなぜか田", "舎に住んでいる"]}, {"box": [353, 2434, 585, 2494], "vertical": false, "font_size": 53, "lines_coords": [[[359.0, 2437.0], [565.0, 2437.0], [565.0, 2490.0], [359.0, 2490.0]]], "lines": ["大事なんだ"]}, {"box": [162, 2606, 221, 3053], "vertical": true, "font_size": 53, "lines_coords": [[[162.0, 2606.0], [215.0, 2606.0], [221.0, 3053.0], [168.0, 3053.0]]], "lines": ["万関どめ上り段深要"]}, {"box": [218, 2618, 362, 2993], "vertical": true, "font_size": 65.5, "lines_coords": [[[225.0, 2618.0], [303.0, 2618.0], [296.0, 2903.0], [218.0, 2903.0]], [[300.0, 2681.0], [353.0, 2681.0], [362.0, 2993.0], [309.0, 2993.0]]], "lines": ["海着くにはこある！から", "た海入階て必"]}, {"box": [221, 2578, 775, 2675], "vertical": false, "font_size": 42.5, "lines_coords": [[[221.0, 2584.0], [775.0, 2578.0], [775.0, 2621.0], [221.0, 2628.0]], [[278.0, 2634.0], [775.0, 2634.0], [775.0, 2675.0], [278.0, 2675.0]]], "lines": ["このある魔法使いいたちが集う魔法機", "あの底に建てられているので、た"]}, {"box": [228, 2884, 290, 3046], "vertical": true, "font_size": 56, "lines_coords": [[[228.0, 2887.0], [284.0, 2884.0], [290.0, 3043.0], [234.0, 3046.0]]], "lines": ["と降潜める"]}, {"box": [912, 2718, 993, 2800], "vertical": false, "font_size": 53, "lines_coords": [[[912.0, 2762.0], [956.0, 2718.0], [993.0, 2756.0], [950.0, 2800.0]]], "lines": ["おおっ"]}, {"box": [850, 2681, 912, 3053], "vertical": true, "font_size": 62, "lines_coords": [[[850.0, 2681.0], [912.0, 2681.0], [912.0, 3053.0], [850.0, 3053.0]]], "lines": ["行昔で、浮合草えて"]}, {"box": [856, 2581, 1181, 3050], "vertical": false, "font_size": 50.083333333333336, "lines_coords": [[[859.0, 2581.0], [1134.0, 2584.0], [1134.0, 2628.0], [859.0, 2625.0]], [[856.0, 2625.0], [1171.0, 2631.0], [1171.0, 2684.0], [856.0, 2678.0]], [[962.0, 2678.0], [1140.0, 2684.0], [1137.0, 2740.0], [959.0, 2734.0]], [[1128.0, 2690.0], [1165.0, 2690.0], [1165.0, 2740.0], [1128.0, 2740.0]], [[1003.0, 2737.0], [1140.0, 2737.0], [1140.0, 2784.0], [1003.0, 2784.0]], [[1118.0, 2759.0], [1150.0, 2728.0], [1181.0, 2759.0], [1150.0, 2790.0]], [[981.0, 2784.0], [1175.0, 2784.0], [1175.0, 2850.0], [981.0, 2850.0]], [[1046.0, 2884.0], [1175.0, 2890.0], [1171.0, 2946.0], [1043.0, 2940.0]], [[984.0, 2840.0], [1171.0, 2840.0], [1171.0, 2893.0], [984.0, 2893.0]], [[896.0, 2896.0], [1068.0, 2896.0], [1068.0, 2940.0], [896.0, 2940.0]], [[893.0, 2996.0], [1046.0, 3006.0], [1043.0, 3050.0], [890.0, 3040.0]], [[950.0, 2953.0], [1168.0, 2946.0], [1168.0, 2990.0], [950.0, 2996.0]]], "lines": ["魔法使いの弟子は", "風呂はメンバーになるための試験が", "これる場所。大", "大", "かれた魔法", "ふ", "なんとか女が空中に", "る。叫歌要な王冠", "いる。試験", "合格に必要な", "．．．は、えていない。", "ここにしか生"]}, {"box": [1762, 2581, 2075, 2675], "vertical": false, "font_size": 40.5, "lines_coords": [[[1762.0, 2581.0], [2065.0, 2581.0], [2065.0, 2621.0], [1762.0, 2621.0]], [[1803.0, 2634.0], [2075.0, 2634.0], [2075.0, 2675.0], [1803.0, 2675.0]]], "lines": ["のアトリエからアクセ", "魔法使いの街。小"]}, {"box": [1621, 2784, 1746, 3043], "vertical": true, "font_size": 44.666666666666664, "lines_coords": [[[1662.0, 2837.0], [1709.0, 2837.0], [1703.0, 3043.0], [1656.0, 3043.0]], [[1703.0, 2784.0], [1746.0, 2784.0], [1746.0, 2996.0], [1703.0, 2996.0]], [[1621.0, 2812.0], [1665.0, 2812.0], [1665.0, 3040.0], [1621.0, 3040.0]]], "lines": ["ど、事だで", "る魔すけ", "をな従間ん"]}, {"box": [1737, 2656, 1793, 2993], "vertical": true, "font_size": 53, "lines_coords": [[[1737.0, 2656.0], [1790.0, 2656.0], [1793.0, 2993.0], [1740.0, 2993.0]]], "lines": ["あ道職法るが"]}], "img_path": "207.avif"}, {"version": "0.2.4", "img_width": 2250, "img_height": 3200, "blocks": [{"box": [1081, 43, 2168, 1678], "vertical": true, "font_size": 580.5, "lines_coords": [[[1668.0, 68.0], [2143.0, 59.0], [2168.0, 1668.0], [1693.0, 1678.0]], [[1081.0, 84.0], [1765.0, 43.0], [1853.0, 1584.0], [1168.0, 1625.0]]], "lines": ["魔法使いと", "悪ばれるはし"]}, {"box": [440, 2337, 1567, 2736], "vertical": false, "font_size": 46, "lines_coords": [[[553.0, 2342.0], [1487.0, 2349.0], [1487.0, 2400.0], [553.0, 2394.0]], [[737.0, 2411.0], [1315.0, 2411.0], [1315.0, 2463.0], [737.0, 2463.0]], [[634.0, 2477.0], [1409.0, 2480.0], [1409.0, 2532.0], [634.0, 2529.0]], [[584.0, 2546.0], [1462.0, 2546.0], [1462.0, 2594.0], [584.0, 2594.0]], [[809.0, 2611.0], [1268.0, 2611.0], [1268.0, 2660.0], [809.0, 2660.0]], [[440.0, 2677.0], [1515.0, 2677.0], [1515.0, 2725.0], [440.0, 2725.0]]], "lines": ["異常事態に不安と苛立ちを募らせるテティアとアガット。", "そんな彼女たちを目の当たりにし、", "巻き添えにしてしまった罪悪感で苦しむココ。", "「『知らざる者』の自分が魔法使いになろうだなんて、", "間違ってたのかな．．．？」", "追い詰められた状況で、四人のとんがり帽子たちが出した答え"]}], "img_path": "208.avif"}, {"version": "0.2.4", "img_width": 2250, "img_height": 3200, "blocks": [{"box": [196, 1462, 731, 1515], "vertical": false, "font_size": 53, "lines_coords": [[[196.0, 1462.0], [731.0, 1462.0], [731.0, 1515.0], [196.0, 1515.0]]], "lines": ["一切関係ありません。"]}, {"box": [165, 1350, 2065, 1406], "vertical": false, "font_size": 53, "lines_coords": [[[165.0, 1353.0], [2065.0, 1350.0], [2065.0, 1403.0], [165.0, 1406.0]]], "lines": ["☆この物語はフィクシヨンです。実在の人物・団体・出来事などとは、"]}, {"box": [225, 1759, 1403, 1812], "vertical": false, "font_size": 53, "lines_coords": [[[225.0, 1759.0], [1403.0, 1759.0], [1403.0, 1812.0], [225.0, 1812.0]]], "lines": ["コミックス発売当時のまま掲載しています。"]}, {"box": [165, 1656, 2056, 1700], "vertical": false, "font_size": 44, "lines_coords": [[[165.0, 1656.0], [2056.0, 1656.0], [2056.0, 1700.0], [165.0, 1700.0]]], "lines": ["淡収録されている内容は、作品の執筆年代・執筆された状況を考慮し、"]}], "img_path": "209.avif"}, {"version": "0.2.4", "img_width": 2250, "img_height": 3200, "blocks": [{"box": [400, 531, 1834, 662], "vertical": false, "font_size": 125, "lines_coords": [[[400.0, 537.0], [1834.0, 531.0], [1834.0, 656.0], [400.0, 662.0]]], "lines": ["とんがり帽子のアトリエ（）"]}, {"box": [621, 1087, 684, 1143], "vertical": false, "font_size": 56, "lines_coords": [[[621.0, 1087.0], [684.0, 1087.0], [684.0, 1143.0], [621.0, 1143.0]]], "lines": ["著"]}, {"box": [550, 1325, 756, 1562], "vertical": false, "font_size": 73.0, "lines_coords": [[[559.0, 1325.0], [746.0, 1325.0], [746.0, 1393.0], [559.0, 1393.0]], [[553.0, 1478.0], [756.0, 1484.0], [753.0, 1562.0], [550.0, 1556.0]]], "lines": ["発行者", "発行所"]}, {"box": [784, 850, 1443, 893], "vertical": false, "font_size": 43, "lines_coords": [[[784.0, 850.0], [1443.0, 850.0], [1443.0, 893.0], [784.0, 893.0]]], "lines": ["２０２３年３月１日発行（０２）"]}, {"box": [887, 1312, 1162, 1403], "vertical": false, "font_size": 91, "lines_coords": [[[887.0, 1312.0], [1162.0, 1312.0], [1162.0, 1403.0], [887.0, 1403.0]]], "lines": ["森田浩章"]}, {"box": [896, 1081, 1706, 1253], "vertical": false, "font_size": 68.5, "lines_coords": [[[909.0, 1081.0], [1093.0, 1081.0], [1093.0, 1146.0], [909.0, 1146.0]], [[896.0, 1171.0], [1706.0, 1181.0], [1706.0, 1253.0], [896.0, 1243.0]]], "lines": ["白浜鴎", "®ＫＡＭＯＭＥＳＨＲＡＨＡＭＡ２０７"]}, {"box": [896, 1490, 1659, 1725], "vertical": false, "font_size": 65.66666666666667, "lines_coords": [[[896.0, 1490.0], [1406.0, 1490.0], [1406.0, 1556.0], [896.0, 1556.0]], [[903.0, 1575.0], [1243.0, 1575.0], [1243.0, 1640.0], [903.0, 1640.0]], [[900.0, 1653.0], [1659.0, 1659.0], [1659.0, 1725.0], [900.0, 1718.0]]], "lines": ["株式会社・講談社", "・〒１１２－８００１", "東京都文京区音羽２１２２１"]}, {"box": [602, 2486, 1563, 2733], "vertical": false, "font_size": 82, "lines_coords": [[[900.0, 2561.0], [1525.0, 2568.0], [1525.0, 2657.0], [900.0, 2650.0]]], "lines": ["【４０ＤＡＮＳＨＡ"]}], "img_path": "210.avif"}]}
